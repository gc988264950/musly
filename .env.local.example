# ─── Supabase ──────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values from the Supabase dashboard.
# https://supabase.com/dashboard/project/<your-project>/settings/api

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Used only server-side (never expose to the client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Cakto Billing ─────────────────────────────────────────────────────────────
# How to find these values:
#   Client ID / Secret: Cakto dashboard → Configurações → API
#   Webhook Secret:     Cakto dashboard → Configurações → Integrações → Webhooks → Chave secreta
#   Checkout links:     Cakto dashboard → Produtos → [your product] → Vender → Copiar link

# Server-side only — never prefix with NEXT_PUBLIC_
CAKTO_CLIENT_ID=your-cakto-client-id
CAKTO_CLIENT_SECRET=your-cakto-client-secret
CAKTO_WEBHOOK_SECRET=your-cakto-webhook-secret

# Client-side safe — these are just checkout redirect URLs, not credentials
# Paste the full Cakto offer link for each plan (e.g. https://pay.cakto.com.br/abc123)
NEXT_PUBLIC_CAKTO_LINK_PRO=https://pay.cakto.com.br/your-pro-offer-code
NEXT_PUBLIC_CAKTO_LINK_STUDIO=https://pay.cakto.com.br/your-studio-offer-code
